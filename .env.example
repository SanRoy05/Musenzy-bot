# ──────────────────────────────────────────────────────────────────────────────
# Musenzy Telegram Music Bot — Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────────────

# ── Telegram API credentials ──────────────────────────────────────────────────
# Get from https://my.telegram.org → "API development tools"
API_ID=
API_HASH=

# ── Bot token ─────────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram
BOT_TOKEN=

# ── Userbot session string ────────────────────────────────────────────────────
# Generate by running:  python generate_session.py
# KEEP THIS SECRET — it grants full access to your Telegram account.
SESSION_STRING=

# ── Access control ────────────────────────────────────────────────────────────
# Your Telegram user ID — the single bot owner (Level 1, highest privilege).
# Get your ID by messaging @userinfobot on Telegram.
# Only this person can use /addsudo, /delsudo, /sudolist.
OWNER_ID=



# ── Player settings ───────────────────────────────────────────────────────────
# Maximum number of tracks allowed in the queue per group (default: 20)
MAX_QUEUE_SIZE=20

# Default playback volume 0-200 (default: 100)
DEFAULT_VOLUME=100

# Directory where audio/video files are temporarily stored during playback.
# Files are deleted automatically after each track finishes.
DOWNLOAD_DIR=/tmp/musenzy

# ── Web Server (Health Check) ──────────────────────────────────────────────────
# Port for the background HTTP server (used by Koyeb/Render for health checks)
PORT=8000
